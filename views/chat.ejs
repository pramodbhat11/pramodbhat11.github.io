<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat with <%= otherUser.name || otherUser.companyName || otherUser.email %> - WasteToWealth</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .chat-container {
            height: 70vh;
            display: flex;
            flex-direction: column;
            border: 1px solid #ddd;
            border-radius: 10px;
            overflow: hidden;
            background-color: #f8f9fa;
        }

        .chat-messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .message {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 20px;
            position: relative;
        }

        .message.sent {
            align-self: flex-end;
            background-color: #007bff;
            color: white;
            border-bottom-right-radius: 5px;
        }

        .message.received {
            align-self: flex-start;
            background-color: #e9ecef;
            color: #333;
            border-bottom-left-radius: 5px;
        }

        .chat-input {
            padding: 15px;
            background-color: white;
            border-top: 1px solid #ddd;
        }

        .time {
            font-size: 0.7em;
            margin-top: 5px;
            display: block;
            opacity: 0.7;
            text-align: right;
        }
    </style>
</head>

<body class="bg-light">

    <!-- Navbar -->
    <header class="navbar navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">WasteToWealth</a>
            <a href="/dashboard" class="btn btn-outline-light btn-sm">Back to Dashboard</a>
        </div>
    </header>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
                        <div class="d-flex align-items-center mb-3">
                            <div class="flex-grow-1">
                                <h5 class="mb-0">Chat with: <strong>
                                        <%= otherUser.name || otherUser.companyName || otherUser.email %>
                                    </strong></h5>
                                <small class="text-muted">Listing: <%= request.listingId ? (request.listingId.wastetype
                                        || request.listingId.wastetypeRequired) : 'Item' %></small>
                            </div>
                            <span class="badge bg-success">Online</span>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="chat-container">
                            <ul class="chat-messages" id="chatMessages">
                                <% chats.forEach(chat=> { %>
                                    <li
                                        class="message <%= chat.senderId.toString() === currentUser._id.toString() ? 'sent' : 'received' %>">
                                        <%= chat.message %>
                                            <span class="time">
                                                <%= new Date(chat.timestamp).toLocaleTimeString([], {hour: '2-digit' ,
                                                    minute:'2-digit'}) %>
                                            </span>
                                    </li>
                                    <% }) %>
                            </ul>

                            <div class="chat-input">
                                <form id="chatForm" class="d-flex gap-2">
                                    <input type="text" id="msgInput" class="form-control"
                                        placeholder="Type a message..." required autocomplete="off">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-paper-plane"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Socket.IO Client -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const requestId = '<%= request._id %>';
        const senderId = '<%= currentUser._id %>';
        const receiverId = '<%= otherUser._id %>';
        const chatBox = document.getElementById('chatMessages');

        // Join room logic
        socket.emit('join', senderId);

        // Scroll to bottom on load
        chatBox.scrollTop = chatBox.scrollHeight;

        // Send Message
        document.getElementById('chatForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const input = document.getElementById('msgInput');
            const message = input.value;

            if (message.trim()) {
                // Emit to server
                socket.emit('send_message', {
                    requestId,
                    senderId,
                    message,
                    receiverId
                });

                // Append locally (optimistic UI)
                const li = document.createElement('li');
                li.classList.add('message', 'sent');
                li.innerHTML = `${message} <span class="time">${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>`;
                chatBox.appendChild(li);
                chatBox.scrollTop = chatBox.scrollHeight;

                input.value = '';
            }
        });

        // Receive Message
        socket.on('receive_message', function (data) {
            if (data.requestId === requestId) {
                const li = document.createElement('li');
                li.classList.add('message', 'received');
                li.innerHTML = `${data.message} <span class="time">${new Date(data.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>`;
                chatBox.appendChild(li);
                chatBox.scrollTop = chatBox.scrollHeight;
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>