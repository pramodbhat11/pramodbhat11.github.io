<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connection Requests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-4">
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link" href="/messages/inbox">Chats</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" href="#">Requests</a>
            </li>
        </ul>

        <h2 class="mb-4">Pending Requests</h2>
        <div id="requests-list" class="list-group">
            <div class="text-center text-muted">Loading requests...</div>
        </div>
    </div>

    <script>
        async function fetchRequests() {
            try {
                const res = await fetch('/messages/requests');
                const data = await res.json();

                const list = document.getElementById('requests-list');
                list.innerHTML = '';

                if (data.requests.length === 0) {
                    list.innerHTML = '<div class="text-center text-muted">No pending requests.</div>';
                    return;
                }

                data.requests.forEach(req => {
                    const item = document.createElement('div');
                    item.className = 'list-group-item d-flex justify-content-between align-items-center';

                    item.innerHTML = `
                        <div>
                            <h5 class="mb-1">${req.name || 'Unknown User'}</h5>
                            <small class="text-muted">Sent ${new Date(req.createdAt).toLocaleDateString()}</small>
                        </div>
                        <div>
                            <button onclick="acceptRequest('${req.conversationId}')" class="btn btn-success btn-sm me-2">Accept</button>
                            <button onclick="rejectRequest('${req.conversationId}')" class="btn btn-danger btn-sm">Decline</button>
                        </div>
                    `;
                    list.appendChild(item);
                });

            } catch (err) {
                console.error("Error loading requests", err);
            }
        }

        async function acceptRequest(conversationId) {
            try {
                const res = await fetch('/messages/accept', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ conversationId })
                });
                const data = await res.json();
                if (data.success) {
                    alert("Accepted!");
                    fetchRequests();
                } else {
                    alert("Error: " + data.error);
                }
            } catch (e) { console.error(e); }
        }

        async function rejectRequest(conversationId) {
            if (!confirm("Are you sure you want to decline?")) return;
            try {
                const res = await fetch('/messages/reject', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ conversationId })
                });
                const data = await res.json();
                if (data.success) {
                    fetchRequests();
                }
            } catch (e) { console.error(e); }
        }

        fetchRequests();
    </script>
</body>

</html>