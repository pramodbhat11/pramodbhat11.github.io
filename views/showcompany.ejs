<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= listing.companyName %> - Company Listing
    </title>
    <link rel="stylesheet" href="/css/show.css">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .badge {
            font-size: 0.75em;
        }
    </style>
</head>

<body>

    <header class="navbar bg-primary text-white py-3">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="logo mb-0">WasteToWealth</h2>
                <nav class="nav-buttons">

                    <a href="/companies" class="btn btn-light">Back to Listings</a>
                </nav>
            </div>
        </div>
    </header>

    <div class="container mt-4">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow">
                    <div class="card-header bg-info text-white">
                        <h1 class="mb-0">Company Listing Details</h1>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <strong>Company Name:</strong>
                                    <p>
                                        <%= listing.companyName %>
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <strong>Waste Type Required:</strong>
                                    <p>
                                        <%= listing.wastetypeRequired %>
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <strong>Required Quantity:</strong>
                                    <p>
                                        <%= listing.requiredQuantity %> kg
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <strong>Offered Price:</strong>
                                    <p class="text-success fw-bold">
                                        <%= listing.offeredPrice ? '₹' + listing.offeredPrice + '/kg' : 'Negotiable' %>
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <strong>Location:</strong>
                                    <p>
                                        <%= listing.location %>
                                    </p>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <strong>Contact Email:</strong>
                                    <p>
                                        <%= listing.contactEmail %>
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <strong>Contact Phone:</strong>
                                    <p>
                                        <%= listing.contactPhone %>
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <strong>Description:</strong>
                                    <p>
                                        <%= listing.description || 'No description provided' %>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-4">
                            <% if(currentUser && currentUser.email===listing.contactEmail) { %>
                                <a href="/companies/<%= listing._id %>/edit" class="btn btn-warning me-2">Edit</a>
                                <form action="/companies/<%= listing._id %>?_method=DELETE" method="POST"
                                    class="d-inline">
                                    <button type="submit" class="btn btn-danger"
                                        onclick="return confirm('Are you sure you want to delete this listing?')">Delete</button>
                                </form>
                                <% } %>

                        </div>
                    </div>
                </div>

                <!-- Similar Company Listings Section -->
                <% if(similarListings && similarListings.length> 0) { %>
                    <div class="card mt-4 shadow">
                        <div class="card-header bg-success text-white">
                            <h3 class="mb-0">Similar Company Listings</h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <% similarListings.forEach(listing=> { %>
                                    <div class="col-md-6 col-lg-4 mb-3">
                                        <div class="card h-100">
                                            <div class="card-body">
                                                <h5 class="card-title">
                                                    <%= listing.companyName %>
                                                </h5>
                                                <p class="card-text"><strong>Type:</strong>
                                                    <%= listing.wastetypeRequired %>
                                                </p>
                                                <p class="card-text"><strong>Req Qty:</strong>
                                                    <%= listing.requiredQuantity %> kg
                                                </p>
                                                <p class="card-text"><strong>Loc:</strong>
                                                    <%= listing.location %>
                                                </p>
                                            </div>
                                            <div class="card-footer">
                                                <a href="/companies/<%= listing._id %>"
                                                    class="btn btn-primary btn-sm w-100">View Details</a>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>
                    </div>
                    <% } %>

                        <!-- Matching Farmer Listings Section -->
                        <% if(matchingFarmers && matchingFarmers.length> 0) { %>
                            <div class="card mt-4 shadow">
                                <div class="card-header bg-warning text-dark">
                                    <h3 class="mb-0">Matching Farmer Listings</h3>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <% matchingFarmers.forEach(farmer=> { %>
                                            <div class="col-md-6 col-lg-4 mb-3">
                                                <div class="card h-100">
                                                    <div class="card-body">
                                                        <h5 class="card-title">
                                                            <%= farmer.farmerName %>
                                                        </h5>
                                                        <p class="card-text"><strong>Type:</strong>
                                                            <%= farmer.wastetype %>
                                                        </p>
                                                        <p class="card-text"><strong>Qty:</strong>
                                                            <%= farmer.quantity %> kg
                                                                <% if(farmer.quantity>= listing.requiredQuantity) { %>
                                                                    <span class="badge bg-success">Sufficient</span>
                                                                    <% } else { %>
                                                                        <span class="badge bg-warning">Limited</span>
                                                                        <% } %>
                                                        </p>
                                                        <p class="card-text"><strong>Loc:</strong>
                                                            <%= farmer.location %>
                                                        </p>
                                                    </div>
                                                    <div class="card-footer">
                                                        <a href="/farmers/<%= farmer._id %>"
                                                            class="btn btn-primary btn-sm w-100">View Details</a>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                                <% if(matchingFarmers && matchingFarmers.length===0) { %>
                                    <div class="card mt-4 shadow">
                                        <div class="card-header bg-secondary text-white">
                                            <h3 class="mb-0">No Matching Farmer Listings Found</h3>
                                        </div>
                                        <div class="card-body">
                                            <p class="mb-0">There are currently no farmers offering <%=
                                                    listing.wastetypeRequired %>. Consider posting your requirement in
                                                    community forums or checking back later.</p>
                                        </div>
                                    </div>
                                    <% } %>
            </div>
        </div>
    </div>


</body>

</html>