<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - WasteToWealth</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .request-card {
            border-left: 5px solid #3498db;
            margin-bottom: 20px;
            transition: transform 0.2s;
        }

        .request-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .status-pending {
            color: #f39c12;
        }

        .status-accepted {
            color: #27ae60;
        }

        .status-rejected {
            color: #e74c3c;
        }

        .nav-pills .nav-link.active {
            background-color: #27ae60;
        }
    </style>
</head>

<body class="bg-light">

    <!-- Navbar -->
    <header class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">WasteToWealth</a>
            <div class="ms-auto">
                <a href="/" class="btn btn-outline-light btn-sm">Back to Home</a>
                <a href="/logout" class="btn btn-danger btn-sm ms-2">Logout</a>
            </div>
        </div>
    </header>

    <div class="container py-4">
        <div class="row">
            <div class="col-12 mb-4">
                <div class="d-flex justify-content-between align-items-end">
                    <div>
                        <h2 class="text-primary"><i class="fas fa-tachometer-alt"></i> Dashboard</h2>
                        <p class="text-muted">Manage your requests and orders</p>
                    </div>
                    <div>

                    </div>
                </div>
            </div>
        </div>

        <ul class="nav nav-pills mb-4" id="pills-tab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pills-incoming-tab" data-bs-toggle="pill"
                    data-bs-target="#pills-incoming" type="button" role="tab">
                    Incoming Requests
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="pills-sent-tab" data-bs-toggle="pill" data-bs-target="#pills-sent"
                    type="button" role="tab">
                    Sent Requests
                </button>
            </li>
        </ul>

        <div class="tab-content" id="pills-tabContent">

            <!-- Incoming Requests Tab -->
            <div class="tab-pane fade show active" id="pills-incoming" role="tabpanel">
                <% if (incomingRequests.length===0) { %>
                    <div class="alert alert-info">No incoming requests yet.</div>
                    <% } else { %>
                        <% incomingRequests.forEach(reqItem=> { %>
                            <div class="card request-card shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h5 class="card-title">
                                            Request for: <strong>
                                                <%= reqItem.listingId ? (reqItem.listingId.wastetype ||
                                                    reqItem.listingId.wastetypeRequired) : 'General Collaboration' %>
                                            </strong>
                                        </h5>
                                        <span
                                            class="badge bg-<%= reqItem.status === 'ACCEPTED' ? 'success' : (reqItem.status === 'REJECTED' ? 'danger' : 'warning') %>">
                                            <%= reqItem.status %>
                                        </span>
                                    </div>
                                    <p class="card-text text-muted mb-1">
                                        From: <strong>
                                            <%= reqItem.senderId ? (reqItem.senderId.name ||
                                                reqItem.senderId.companyName || reqItem.senderId.email) : 'Unknown User'
                                                %>
                                        </strong>
                                    </p>


                                    <% if (reqItem.status==='PENDING' ) { %>
                                        <div class="mt-3">
                                            <button onclick="updateStatus('<%= reqItem._id %>', 'ACCEPTED')"
                                                class="btn btn-success btn-sm me-2">
                                                <i class="fas fa-check"></i> Accept
                                            </button>
                                            <button onclick="updateStatus('<%= reqItem._id %>', 'REJECTED')"
                                                class="btn btn-outline-danger btn-sm">
                                                <i class="fas fa-times"></i> Reject
                                            </button>
                                        </div>
                                        <% } else if (reqItem.status==='ACCEPTED' ) { %>
                                            <div class="mt-3">

                                                <a href="/order/<%= reqItem._id %>"
                                                    class="btn btn-secondary btn-sm ms-1">
                                                    <i class="fas fa-box-open"></i> Track Order
                                                </a>
                                            </div>
                                            <% } %>
                                </div>
                            </div>
                            <% }) %>
                                <% } %>
            </div>

            <!-- Sent Requests Tab -->
            <div class="tab-pane fade" id="pills-sent" role="tabpanel">
                <% if (sentRequests.length===0) { %>
                    <div class="alert alert-info">You haven't sent any requests yet.</div>
                    <% } else { %>
                        <% sentRequests.forEach(reqItem=> { %>
                            <div class="card request-card shadow-sm" style="border-left-color: #9b59b6;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h5 class="card-title">
                                            Request for: <strong>
                                                <%= reqItem.listingId ? (reqItem.listingId.wastetype ||
                                                    reqItem.listingId.wastetypeRequired) : 'General Collaboration' %>
                                            </strong>
                                        </h5>
                                        <span
                                            class="badge bg-<%= reqItem.status === 'ACCEPTED' ? 'success' : (reqItem.status === 'REJECTED' ? 'danger' : 'warning') %>">
                                            <%= reqItem.status %>
                                        </span>
                                    </div>
                                    <p class="card-text text-muted mb-1">
                                        To: <strong>
                                            <%= reqItem.receiverId ? (reqItem.receiverId.name ||
                                                reqItem.receiverId.companyName || reqItem.receiverId.email)
                                                : 'Unknown User' %>
                                        </strong>
                                    </p>
                                    <p class="card-text small text-muted">
                                        Sent on: <%= reqItem.createdAt.toLocaleDateString() %>
                                    </p>

                                    <% if (reqItem.status==='ACCEPTED' ) { %>
                                        <div class="mt-3">

                                            <a href="/order/<%= reqItem._id %>" class="btn btn-secondary btn-sm ms-1">
                                                <i class="fas fa-box-open"></i> Track Order
                                            </a>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                            <% }) %>
                                <% } %>
            </div>

        </div>
    </div>

    <!-- Script for Status Updates -->
    <script>
        async function updateStatus(requestId, newStatus) {
            if (!confirm('Are you sure you want to ' + newStatus + ' this request?')) return;

            try {
                const response = await fetch(`/request/${requestId}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + data.error);
                }
            } catch (e) {
                console.error(e);
                alert('Failed to update status');
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>